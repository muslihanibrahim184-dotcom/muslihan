# Supabase > Settings > API Keys
# Tarayıcı (frontend) için: publishable (sb_publishable_...) veya legacy anon key
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxx

# SADECE sunucu için (admin işlemleri: kullanıcı şifresi değiştirme).
# secret (sb_secret_...) veya legacy service_role key. ASLA NEXT_PUBLIC yapma!
SUPABASE_SECRET_KEY=sb_secret_xxxx
